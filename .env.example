# ShipStation API credentials
# Generate at: https://app.shipstation.com/settings/api
SS_API_KEY=your_shipstation_api_key
SS_API_SECRET=your_shipstation_api_secret

# Shopify
# SHOPIFY_STORE = yourstore (the part before .myshopify.com)
# Token: Apps → Develop apps → your app → API credentials → Admin API access token
SHOPIFY_STORE=yourstore
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxx

# Optional: override the default 90-day look-back window
# AUDIT_START_DATE=2025-01-01
# AUDIT_END_DATE=2025-03-31

# Web dashboard credentials (index.php)
# NOTE: if data/users.json exists it takes precedence over WEB_USERNAME / WEB_PASSWORD
# and enables multi-user mode with roles (viewer / operator / admin).
# See data/users.json.example for the file format.
WEB_USERNAME=admin
WEB_PASSWORD="change_me_now"

# Dashboard branding (optional)
# ← subtitle in login + browser tab
# APP_TITLE=SS ↔ Shopify Audit
# ← replaces brand text with an image
# APP_LOGO=https://example.com/logo.png
# ← decorative right-column image on login screen (falls back to gradient if unset)
# LOGIN_BG_IMAGE=https://example.com/your-photo.jpg

# Cache TTL in seconds (default 82800 = 23 hours). Set to 0 to disable.
# CACHE_TTL=82800

# Slack audit notifications (optional)
# Create an Incoming Webhook in Slack and paste the URL here.
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/yyy/zzz

# Email / SMTP notifications (optional)
# Requires SMTP_HOST + ALERT_EMAIL at minimum. Uses PHPMailer if installed,
# otherwise falls back to PHP's built-in mail() function.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=user@example.com
# SMTP_PASS=yourpassword
# SMTP_FROM=shopify-ops@example.com
# ALERT_EMAIL=ops-team@example.com
# SMTP_SECURE=tls

# Discord notifications (optional)
# Create an Incoming Webhook in your Discord server and paste the URL here.
# DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# Prometheus metrics endpoint (metrics.php)
# If set, the endpoint requires "Authorization: Bearer <token>" or "?token=<token>".
# Leave empty to allow unauthenticated access (dev mode).
# METRICS_TOKEN=

# Set to 1 to print full stack traces on errors
# DEBUG=1
